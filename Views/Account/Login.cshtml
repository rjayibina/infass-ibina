@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Login - Ibina Infass</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link href="~/css/login.css" rel="stylesheet" />
</head>
<body>
    <main class="login-main">
        <div class="login-card">
            <h1 class="login-title">Login</h1>
            <div class="star-divider"></div>
            <form class="login-form" method="post" action="/Account/Login">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" placeholder="rjayibinacute" required />
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="password-wrapper">
                        <input type="password" id="password" name="password" placeholder="••••••••" required />
                    </div>
                    <div class="show-password-row">
                        <div class="show-password-check">
                            <input type="checkbox" id="showPassword" onchange="togglePassword()" />
                            <label for="showPassword">Show Password</label>
                        </div>
                        <a href="#" class="forgot-link">Forgot Password?</a>
                    </div>
                </div>
                <button type="submit" class="btn-login">Login</button>
            </form>
            <p class="signup-redirect">
                Don't have an account?
                <a href="/Account/Signup">Sign up</a>
            </p>
        </div>
    </main>
    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const showPassword = document.getElementById('showPassword');
            passwordInput.type = showPassword.checked ? 'text' : 'password';
        }
    </script>
</body>
</html>